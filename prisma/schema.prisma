// ───── Cluster A: Support ─────
enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MessageAuthorType {
  CUSTOMER
  STAFF
  AI_BOT
  SYSTEM
}

model SupportTicket {
  id          String          @id @default(uuid())
  merchantId  String
  userId      String
