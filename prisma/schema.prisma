// =====================================================================
// Sprint D-1 — Insight model. Coexists with CustomerDailyBrief (cache);
// Insight is the immutable history log. See docs/sprint-d1-discovery.
// =====================================================================
enum InsightType {
  CRITICAL
  ATTENTION
  OPPORTUNITY
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  RESOLVED
  ARCHIVED
}

model Insight {
  id            String        @id @default(cuid())
  merchantId    String
  type          InsightType
  category      String
  title         String
  body          String        @db.Text
  ctaLabel      String?
  ctaRoute      String?
  numericRefs   Json?
  language      String
  source        String
  status        InsightStatus @default(ACTIVE)
  generatedAt   DateTime      @default(now())
  expiresAt     DateTime?
  dismissedAt   DateTime?
  resolvedAt    DateTime?
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shares        InsightShare[]
  notifications Notification[]

  @@index([merchantId, status, generatedAt])
  @@index([merchantId, type, status])
  @@map("insights")
}

// =====================================================================
// Sprint D-3 — Sharing recipients + insight share log.
// =====================================================================
model SharingRecipient {
  id           String    @id @default(cuid())
  merchantId   String
  name         String
  email        String?
  phone        String?
  role         String?
  avatarUrl    String?
  lastUsedAt   DateTime?
  shareCount   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  merchant     Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shares       InsightShare[]

  @@index([merchantId, lastUsedAt])
  @@map("sharing_recipients")
}

model InsightShare {
  id                String    @id @default(cuid())
  merchantId        String
  insightId         String?
  reportType        String
  channel           String
  recipientId       String?
  recipientSnapshot Json
  message           String    @db.Text
  pdfShareToken     String?   @unique
  status            String    @default("sent")
  providerMessageId String?                                   // Resend email ID — used by D-4 webhook to update deliveredAt/openedAt
  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?
  openedAt          DateTime?
  errorMessage      String?
  downloadCount     Int       @default(0)
  firstDownloadedAt DateTime?
  merchant          Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  insight           Insight?          @relation(fields: [insightId], references: [id], onDelete: SetNull)
  recipient         SharingRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([merchantId, sentAt])
  @@index([recipientId, sentAt])
  @@index([pdfShareToken])
  @@map("insight_shares")
}

model SystemAlert {
  id         String    @id @default(uuid())
  type       String
  severity   String
  title      String
  message    String
  metadata   Json?
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  @@index([severity, isResolved])
  @@index([type, createdAt])
  @@map("system_alerts")
}

// =====================================================================
// Sprint D-5 — Daily AI Briefing Email Digest.
//   MorningBriefSubscription — per-merchant opt-in + schedule + bounce
//                              counter for the morning email digest.
//   MorningBriefSend          — immutable send-log row for engagement
//                              tracking (delivered/opened/clicked/bounced).
//
// Naming chosen to avoid collision with the existing `customer_daily_brief`
// in-app cache table (Phase 16). "Morning" matches the user-facing
// "Zyrix Morning Brief" subject line.
// =====================================================================
model MorningBriefSubscription {
  id              String    @id @default(cuid())
  merchantId      String    @unique
  enabled         Boolean   @default(true)
  frequency       String    @default("daily")   // 'daily' | 'weekdays' | 'weekly' | 'never'
  weeklyDay       Int?                           // 0=Sunday..6=Saturday; only used when frequency='weekly'
  sendHourLocal   Int       @default(7)          // 0-23 in Merchant.timezone
  lastSentAt      DateTime?
  bounceCount     Int       @default(0)          // hard bounces; auto-disable at >= 3
  variant         String    @default("v1")       // A/B variant key (V1 ships only "v1")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("morning_brief_subscriptions")
}

model MorningBriefSend {
  id                  String    @id @default(cuid())
  merchantId          String
  variant             String    @default("v1")
  subject             String
  insightIds          String[]                    // Insight rows fed into this send
  providerMessageId   String?                     // Resend message ID — webhook lookup key
  status              String    @default("sent")  // 'sent' | 'delivered' | 'opened' | 'failed'
  sentAt              DateTime  @default(now())
  deliveredAt         DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  bouncedAt           DateTime?
  bounceReason        String?
  unsubscribeClicked  Boolean   @default(false)
  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, sentAt])
  @@index([providerMessageId])
  @@map("morning_brief_sends")
}
