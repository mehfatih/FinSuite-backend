  snapshotData     Json?
  createdAt        DateTime        @default(now())

  @@index([merchantId, status])
  @@map("migration_jobs")
}

model ExportJob {
  id          String       @id @default(uuid())
  merchantId  String
  userId      String
  type        String
  format      String
  schedule    String?
  status      ExportStatus @default(PENDING)
  fileUrl     String?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([merchantId, status])
  @@map("export_jobs")
}

// ───── Cluster C: Security ─────
model TwoFactorAuth {
