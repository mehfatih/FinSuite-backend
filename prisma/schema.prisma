model CustomerArchive {
  id                String    @id @default(uuid())
  originalCompanyId String    @unique
  originalUserId    String
  archivedData      Json
  reason            String
  archivedBy        String
  archivedAt        DateTime  @default(now())
  scheduledPurgeAt  DateTime
  restoredAt        DateTime?
  restoredBy        String?

  @@index([originalCompanyId])
  @@index([scheduledPurgeAt])
  @@map("customer_archives")
}

model AdminNotification {
  id          String   @id @default(uuid())
  adminUserId String?
  type        String
  title       String
  message     String
  severity    String   @default("info")
  link        String?
  isRead      Boolean  @default(false)
