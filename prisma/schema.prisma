// =====================================================================
// PHASE 14 — Admin Operations Center
// =====================================================================

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model AdminAuditLog {
  id           String        @id @default(uuid())
  adminUserId  String
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  beforeState  Json?
  afterState   Json?
  severity     AuditSeverity @default(INFO)
  createdAt    DateTime      @default(now())

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([action])
  @@index([severity, createdAt])
  @@map("admin_audit_logs")
}

model ImpersonationSession {
  id                 String    @id @default(uuid())
  adminUserId        String
  adminEmail         String?
  customerUserId     String
  targetCustomerName String?
  reason             String
  consentGranted     Boolean   @default(false)
  consentToken       String?
  durationMinutes    Int       @default(30)
  startedAt          DateTime  @default(now())
  expiresAt          DateTime?
  endedAt            DateTime?
  endReason          String?
  ipAddress          String?
  userAgent          String?

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([customerUserId])
  @@index([expiresAt])
  @@map("impersonation_sessions")
}

model CustomerDashboardPreference {
  id                String   @id @default(uuid())
  customerUserId    String   @unique
  kpiSlots          Json     @default("[\"mrr\",\"cash_runway\",\"customer_health_pct\",\"tax_burden\"]")
  aiCoPilotFocus    String   @default("all")
  sidebarCollapsed  Json     @default("{}")
  language          String   @default("tr")
  role              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([customerUserId])
  @@map("customer_dashboard_preferences")
}

model CustomerDailyBrief {
  id                String   @id @default(uuid())
  customerUserId    String
  briefDate         DateTime @db.Date
  criticalCard      Json?
  attentionCard     Json?
  opportunityCard   Json?
  focusArea         String   @default("all")
  generatedAt       DateTime @default(now())
  expiresAt         DateTime

  @@unique([customerUserId, briefDate])
  @@index([customerUserId, briefDate])
  @@index([expiresAt])
  @@map("customer_daily_brief")
