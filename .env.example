# ============================================================
# Zyrix FinSuite Backend - Environment Variables
# ============================================================
# Copy this file to .env (local) or set these on Railway dashboard.
# Never commit .env with real values.
# ============================================================

# ───────── Core ─────────
NODE_ENV=production
PORT=3000

# ───────── Database (Railway provides) ─────────
DATABASE_URL=postgresql://user:pass@host:port/dbname

# ───────── Auth ─────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex
JWT_ADMIN_SECRET=replace-with-different-64-char-hex

# ───────── AI (Gemini) ─────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ───────── Email (Resend) ─────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=

# ───────── Payments (Iyzico) ─────────
# Sandbox: https://sandbox.iyzipay.com  |  Production: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com

# ───────── WhatsApp Business Cloud API ─────────
# 1. Get token + phone ID from https://developers.facebook.com/apps
#    -> WhatsApp -> Getting Started
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=

# 2. WHATSAPP_VERIFY_TOKEN: any random string YOU choose.
#    Use the same value when configuring webhook in Meta dashboard.
#    Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_VERIFY_TOKEN=

# ───────── Cron Jobs ─────────
# Used by /api/whatsapp/reminders/run-all (daily reminder cron).
# Generate any random string. Pass via x-cron-secret header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ───────── Banks (sandbox toggle) ─────────
# When true, bank adapters return synthetic test data.
# Real BBM-OBKS API agreements required for production = false.
BANK_SANDBOX_MODE=true
